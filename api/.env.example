# MongoDB Atlas connection string (M0 free tier works)
# Get yours at https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elevaite?retryWrites=true&w=majority

# Server
PORT=4000

# CORS — the Vercel URL of the web app
WEB_ORIGIN=http://localhost:3000
