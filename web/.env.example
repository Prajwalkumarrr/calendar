# Public API URL — set to your Render service URL in production
NEXT_PUBLIC_API_URL=http://localhost:4000

# MongoDB Atlas — same connection string as api/.env (NextAuth shares the cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elevaite?retryWrites=true&w=majority

# NextAuth — set NEXTAUTH_URL in production to the deployed URL
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Google OAuth — see README "Set up Google OAuth"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
